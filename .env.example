# API Credentials
IDEALISTA_API_KEY=your_api_key_here
IDEALISTA_SECRET=your_secret_here

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/credentials.json
GCP_PROJECT_ID=your-gcp-project-id

# BigQuery
BIGQUERY_DATASET_RAW=idealista_raw
BIGQUERY_DATASET_STAGING=idealista_staging
BIGQUERY_DATASET_INTERMEDIATE=idealista_intermediate
BIGQUERY_DATASET_MART=idealista_mart

# Airflow
AIRFLOW_HOME=/path/to/airflow

# Extraction Settings
EXTRACTION_CITIES=madrid,barcelona
EXTRACTION_PROPERTY_TYPES=sale,rent
EXTRACTION_MAX_PAGES=10
EXTRACTION_FREQUENCY=daily

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
