# Idealista API Credentials
# ========================
# 
# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your real credentials
# 3. Never commit .env to git (already in .gitignore)

# Idealista API credentials (get from https://developers.idealista.com)
IDEALISTA_API_KEY=your_api_key_here
IDEALISTA_SECRET=your_secret_here

# Optional: BigQuery credentials (if using service account)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Optional: Other environment variables
# ENVIRONMENT=development
# LOG_LEVEL=INFO
